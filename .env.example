# ══════════════════════════════════════════
#   CyberBuddy v5.0 — Environment Config
# ══════════════════════════════════════════

# ── SERVER ──────────────────────────────────
PORT=3000
NODE_ENV=development
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# ── DATABASE (Neon PostgreSQL) ───────────────
# Get from: neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── AI CHAT (Groq — free) ────────────────────
# Get from: console.groq.com
GROQ_API_KEY=your_groq_key_here

# ── IMAGE SCAN (Anthropic) ───────────────────
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── PAYMENTS (Flutterwave) ───────────────────
# Get from: flutterwave.com → Settings → API Keys
FLW_PUBLIC_KEY=your_flw_public_key
FLW_SECRET_KEY=your_flw_secret_key

# ── EMAIL (Gmail) ────────────────────────────
# Gmail: myaccount.google.com → Security → App Passwords
GMAIL_USER=your@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx

# ── APP ──────────────────────────────────────
APP_URL=http://localhost:3000
APP_NAME=CyberBuddy
PREMIUM_PRICE_USD=2
FREE_CHAT_LIMIT=10

# ── ADMIN ────────────────────────────────────
# Change this before going live!
ADMIN_PASSWORD=admin123

# ── SECURITY ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
